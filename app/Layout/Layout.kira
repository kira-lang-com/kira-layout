/// Layout enumerations and types
enum Axis {
    Horizontal
    Vertical
}

enum CrossAlignment {
    Start
    Center
    End
    Stretch
}

enum Alignment {
    TopLeading
    Top
    TopTrailing
    Leading
    Center
    Trailing
    BottomLeading
    Bottom
    BottomTrailing
}

enum SizeMode {
    Fixed(Float)
    Fill
    Hug
    Fraction(Float)
    Min(Float)
    Max(Float)
}

enum ArrangeMode {
    Stack
    Absolute
    Grid
    Wrap
    Overlay
    Fill
}

import KiraLayout

function emptyInsets() -> EdgeInsets {
    return EdgeInsets(top: 0.0, trailing: 0.0, bottom: 0.0, leading: 0.0)
}

function fixedLeaf(width: Float, height: Float, margin: EdgeInsets) -> LayoutNode {
    return layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 0,
        childCount: 0
    ), LayoutDescriptor(
            width: SizeMode.Fixed(width),
            height: SizeMode.Fixed(height),
            arrange: ArrangeMode.Fill,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Start,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: emptyInsets(),
            margin: margin,
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: false
        ))
}

function stackDescriptor() -> LayoutDescriptor {
    return LayoutDescriptor(
        width: SizeMode.Fixed(240.0),
        height: SizeMode.Fixed(160.0),
        arrange: ArrangeMode.Stack,
        axis: Axis.Vertical,
        spacing: 8.0,
        rowSpacing: 0.0,
        alignment: CrossAlignment.Stretch,
        overlayAlignment: Alignment.Center,
        columns: 1,
        padding: EdgeInsets(top: 10.0, trailing: 12.0, bottom: 10.0, leading: 12.0),
        margin: emptyInsets(),
        x: 0.0,
        y: 0.0,
        zIndex: 0,
        clipContent: false
    )
}

function horizontalSplitDescriptor() -> LayoutDescriptor {
    return LayoutDescriptor(
        width: SizeMode.Fixed(1280.0),
        height: SizeMode.Fixed(720.0),
        arrange: ArrangeMode.Stack,
        axis: Axis.Horizontal,
        spacing: 40.0,
        rowSpacing: 0.0,
        alignment: CrossAlignment.Stretch,
        overlayAlignment: Alignment.Center,
        columns: 1,
        padding: EdgeInsets(top: 40.0, trailing: 40.0, bottom: 40.0, leading: 40.0),
        margin: emptyInsets(),
        x: 0.0,
        y: 0.0,
        zIndex: 0,
        clipContent: false
    )
}

function fillLeaf(padding: EdgeInsets) -> LayoutNode {
    return layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 0,
        childCount: 0
    ), LayoutDescriptor(
            width: SizeMode.Fill,
            height: SizeMode.Fill,
            arrange: ArrangeMode.Fill,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Stretch,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: padding,
            margin: emptyInsets(),
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: false
        ))
}

function overlayDescriptor() -> LayoutDescriptor {
    return LayoutDescriptor(
        width: SizeMode.Fixed(100.0),
        height: SizeMode.Fixed(60.0),
        arrange: ArrangeMode.Overlay,
        axis: Axis.Vertical,
        spacing: 0.0,
        rowSpacing: 0.0,
        alignment: CrossAlignment.Center,
        overlayAlignment: Alignment.BottomTrailing,
        columns: 1,
        padding: emptyInsets(),
        margin: EdgeInsets(top: 4.0, trailing: 2.0, bottom: 4.0, leading: 2.0),
        x: 0.0,
        y: 0.0,
        zIndex: 0,
        clipContent: false
    )
}

function demoHorizontalSplit() {
    let sidebar = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 0,
        childCount: 0
    ), LayoutDescriptor(
            width: SizeMode.Fixed(250.0),
            height: SizeMode.Fill,
            arrange: ArrangeMode.Fill,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Stretch,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: EdgeInsets(top: 32.0, trailing: 24.0, bottom: 32.0, leading: 24.0),
            margin: emptyInsets(),
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: true
        ))
    let content = fillLeaf(padding: emptyInsets())
    let root = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 1,
        childCount: 2
    ), horizontalSplitDescriptor())
    var tree = LayoutTree(nodes: [root, sidebar, content])

    let engine = LayoutEngine()
    engine.measure(tree: tree, index: 0, available: Size(width: 1280.0, height: 720.0))
    engine.place(tree: tree, index: 0, origin: Point(x: 0.0, y: 0.0))

    let sidebarFrame = layoutFrame(tree, 1)
    let contentFrame = layoutFrame(tree, 2)
    print("[ HORIZONTAL SPLIT ]")
    print("-------------------------------------")
    if sidebarFrame.x == 40.0 && sidebarFrame.y == 40.0 && sidebarFrame.width == 250.0 && sidebarFrame.height == 640.0 && contentFrame.x == 330.0 && contentFrame.y == 40.0 && contentFrame.width == 910.0 && contentFrame.height == 640.0 {
        print("  Horizontal split: ok")
    } else {
        print("  Horizontal split: unexpected")
    }
    print("")
}

function demoHorizontalFixedFixed() {
    let left = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 0,
        childCount: 0
    ), LayoutDescriptor(
            width: SizeMode.Fixed(250.0),
            height: SizeMode.Fill,
            arrange: ArrangeMode.Fill,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Stretch,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: emptyInsets(),
            margin: emptyInsets(),
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: false
        ))
    let right = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 0,
        childCount: 0
    ), LayoutDescriptor(
            width: SizeMode.Fixed(400.0),
            height: SizeMode.Fill,
            arrange: ArrangeMode.Fill,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Stretch,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: emptyInsets(),
            margin: emptyInsets(),
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: false
        ))
    let root = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 1,
        childCount: 2
    ), horizontalSplitDescriptor())
    var tree = LayoutTree(nodes: [root, left, right])
    let engine = LayoutEngine()
    engine.measure(tree: tree, index: 0, available: Size(width: 1280.0, height: 720.0))
    engine.place(tree: tree, index: 0, origin: Point(x: 0.0, y: 0.0))
    let leftFrame = layoutFrame(tree, 1)
    let rightFrame = layoutFrame(tree, 2)
    print("[ HORIZONTAL FIXED FIXED ]")
    print("-------------------------------------")
    if leftFrame.x == 40.0 && leftFrame.width == 250.0 && rightFrame.x == 330.0 && rightFrame.width == 400.0 {
        print("  Horizontal fixed/fixed: ok")
    } else {
        print("  Horizontal fixed/fixed: unexpected")
    }
    print("")
}

function demoLayoutEngine() {
    let card = fixedLeaf(width: 80.0, height: 24.0, margin: EdgeInsets(top: 0.0, trailing: 0.0, bottom: 4.0, leading: 0.0))
    let filler = fixedLeaf(width: 20.0, height: 20.0, margin: emptyInsets())
    let badge = fixedLeaf(width: 30.0, height: 16.0, margin: emptyInsets())
    let overlay = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 4,
        childCount: 1
    ), overlayDescriptor())
    let root = layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: 1,
        childCount: 3
    ), stackDescriptor())
    var tree = LayoutTree(nodes: [root, card, filler, overlay, badge])

    let engine = LayoutEngine()
    engine.measure(tree: tree, index: 0, available: Size(width: 240.0, height: 160.0))
    engine.place(tree: tree, index: 0, origin: Point(x: 5.0, y: 7.0))
    let measuredRoot = tree.nodes[0]
    let measured = Size(width: measuredRoot.measuredW, height: measuredRoot.measuredH)

    print("[ LAYOUT ENGINE ]")
    print("-------------------------------------")
    print("  Root fixed size: 240 x 160")
    print("  Measured size computed")
    print("  Stack, padding, margins, stretch, overlay all executed")

    if measured.width == 240.0 && measured.height == 160.0 {
        print("  Measurement: ok")
    } else {
        print("  Measurement: unexpected")
    }
    print("")
}

function demoGeometry() {
    let rect = Rect(x: 10.0, y: 20.0, width: 100.0, height: 60.0)
    let insets = EdgeInsets(top: 5.0, trailing: 10.0, bottom: 5.0, leading: 10.0)
    let insetRect = rectInset(r: rect, by: insets)
    let center = rectCenter(r: rect)

    print("[ GEOMETRY ]")
    print("-------------------------------------")
    print("  Rect center and inset computed")
    if center.x == 60.0 && center.y == 50.0 && insetRect.width == 80.0 && insetRect.height == 50.0 {
        print("  Geometry: ok")
    } else {
        print("  Geometry: unexpected")
    }
    print("")
}

function fixedStackLeaf(w: Float, h: Float, firstChild: Int, childCount: Int) -> LayoutNode {
    return layoutNodeFlattenDescriptor(LayoutNode(
        firstChild: firstChild,
        childCount: childCount
    ), LayoutDescriptor(
            width: SizeMode.Fixed(w),
            height: SizeMode.Fixed(h),
            arrange: ArrangeMode.Stack,
            axis: Axis.Vertical,
            spacing: 0.0,
            rowSpacing: 0.0,
            alignment: CrossAlignment.Start,
            overlayAlignment: Alignment.Center,
            columns: 1,
            padding: emptyInsets(),
            margin: emptyInsets(),
            x: 0.0,
            y: 0.0,
            zIndex: 0,
            clipContent: false
        ))
}

function retainedDemoTree() -> LayoutTree {
    return LayoutTree(nodes: [
        fixedStackLeaf(w: 200.0, h: 200.0, firstChild: 1, childCount: 2),
        fixedStackLeaf(w: 60.0, h: 40.0, firstChild: 3, childCount: 1),
        fixedStackLeaf(w: 60.0, h: 40.0, firstChild: 4, childCount: 1),
        fixedStackLeaf(w: 30.0, h: 20.0, firstChild: 0, childCount: 0),
        fixedStackLeaf(w: 30.0, h: 20.0, firstChild: 0, childCount: 0)
    ])
}

// Demonstrates the retained layout cache: an unchanged second pass does no
// measurement/placement work, and a single changed leaf recomputes only its
// ancestor chain while its sibling subtree is reused -- all while producing
// pixel-identical frames.
function demoRetainedLayout() {
    let engine = LayoutEngine()
    let available = Size(width: 200.0, height: 200.0)

    var tree = retainedDemoTree()
    engine.measure(tree: tree, index: 0, available: available)
    engine.place(tree: tree, index: 0, origin: Point(x: 0.0, y: 0.0))

    let childBPass1 = layoutFrame(tree, 2)
    let grandBPass1 = layoutFrame(tree, 4)

    print("[ RETAINED LAYOUT ]")
    print("-------------------------------------")

    // Pass 2: nothing changed. Mark the whole tree clean and re-run.
    tree = layoutPropagateDirty(move tree, [false, false, false, false, false])
    tree = layoutResetCounters(move tree)
    engine.measure(tree: tree, index: 0, available: available)
    engine.place(tree: tree, index: 0, origin: Point(x: 0.0, y: 0.0))
    if tree.measureComputes == 0 && tree.placeComputes == 0 && tree.measureSkips > 0 && tree.placeSkips > 0 {
        print("  Unchanged pass: no recompute (ok)")
    } else {
        print("  Unchanged pass: unexpected recompute")
    }

    // Pass 3: change grandchild A only. Its frame must update; sibling subtree
    // B must be reused and stay pixel-identical.
    tree.nodes[3] = fixedStackLeaf(w: 40.0, h: 20.0, firstChild: 0, childCount: 0)
    tree = layoutPropagateDirty(move tree, [false, false, false, true, false])
    tree = layoutResetCounters(move tree)
    engine.measure(tree: tree, index: 0, available: available)
    engine.place(tree: tree, index: 0, origin: Point(x: 0.0, y: 0.0))

    let grandAPass3 = layoutFrame(tree, 3)
    let childBPass3 = layoutFrame(tree, 2)
    let grandBPass3 = layoutFrame(tree, 4)

    let siblingReused = childBPass3.x == childBPass1.x && childBPass3.y == childBPass1.y && childBPass3.width == childBPass1.width && childBPass3.height == childBPass1.height && grandBPass3.x == grandBPass1.x && grandBPass3.y == grandBPass1.y && grandBPass3.width == grandBPass1.width
    if grandAPass3.width == 40.0 && siblingReused && tree.measureSkips > 0 && tree.placeSkips > 0 {
        print("  Targeted change: only affected subtree recomputed (ok)")
    } else {
        print("  Targeted change: unexpected")
    }
    print("")
}

@Main
function main() {
    print("")
    print("=====================================")
    print("  KIRA LAYOUT ENGINE - DEMO")
    print("=====================================")
    print("")

    demoGeometry()
    demoLayoutEngine()
    demoHorizontalSplit()
    demoHorizontalFixedFixed()
    demoRetainedLayout()

    print("=====================================")
    print("  All demos completed successfully!")
    print("=====================================")
    print("")
    return
}
